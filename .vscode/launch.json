{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build, Sign & Debug HelloWorldApp",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/.build/arm64-apple-macosx/debug/HelloWorldApp",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Kill, Build and Sign HelloWorldApp",
            "terminal": "integrated"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:embeddock-maccontain}",
            "name": "Debug HelloWorldApp",
            "target": "HelloWorldApp",
            "configuration": "debug",
            "preLaunchTask": "swift: Build Debug HelloWorldApp"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:embeddock-maccontain}",
            "name": "Release HelloWorldApp",
            "target": "HelloWorldApp",
            "configuration": "release",
            "preLaunchTask": "swift: Build Release HelloWorldApp"
        }
    ]
}